local lighting = game:GetService("Lighting");

local savedSections = Instance.new("Folder");

savedSections.Name = "savedSections";
savedSections.Parent = lighting;

local function moveSections(tower: Model)
	local sections = tower:WaitForChild("sections", math.huge);
	print("Waiting for sections to move them.");

	if sections then
		local lobby = sections:WaitForChild("lobby", math.huge);
		print("Waiting for the lobby.");

		if lobby then
			for _, sectionModel in sections:GetChildren() do
				if sectionModel.Name ~= "lobby" and sectionModel.Name ~= "finish" then
					sectionModel:PivotTo(lobby:GetPivot());
				end;
			end;
		else
			warn("Lobby not found.");
		end;
	else
		warn("Sections not found.");
	end;
end;

local function saveSections(tower: Model)
	local sections = tower:WaitForChild("sections", math.huge);
	print("Waiting for sections to save them.");

	if sections then
		for _, sectionModel in sections:GetChildren() do
			if sectionModel.Name ~= "lobby" and sectionModel.Name ~= "finish" then
				if not table.find(alreadySaved, sectionModel.Name) then
					sectionModel:Clone().Parent = savedSections;
				end;
			end;
		end;
	else
		warn("Sections not found.");
	end;
end;

workspace.ChildAdded:Connect(function(child: Instance)
	if child:IsA("Model") and child.Name == "tower" then
		task.wait(1);
		moveSections(child);
		task.wait(1);
		saveSections(child);
	end;
end);
