local sectionsToSave = {
	"Hex";
	"Loose Bricks";
};

local lighting = game:GetService("Lighting");
local players = game:GetService("Players");

local localPlayer = players.LocalPlayer;
local savedSections = Instance.new("Folder");

savedSections.Name = "savedSections";
savedSections.Parent = lighting;

local function teleportPlayer(tower: Model)
	local sections = tower:WaitForChild("sections", math.huge);
	print("Waiting for sections...");
	
	local character = localPlayer.Character or localPlayer.CharacterAdded:Wait();
	print("Waiting for character...");

	local humanoidRootPart = character:WaitForChild("HumanoidRootPart", math.huge) :: BasePart;
	print("Waiting for HumanoidRootPart...");
	
	local humanoid = character:WaitForChild("Humanoid", math.huge) :: Humanoid;
	print("Waiting for humanoid...");
	
	if character and humanoidRootPart and humanoid and sections then
		for _, sectionModel in sections:GetChildren() do
			if table.find(sectionsToSave, sectionModel.Name) then
				local start = sectionModel:WaitForChild("start") :: BasePart;
				print("Found", sectionModel.Name, "waitig for start part...");
				
				if start then
					humanoidRootPart.CFrame = CFrame.new(start.CFrame.Position) + Vector3.new(0, humanoid.HipHeight, 0);
					print("Teleported player to section", sectionModel.Name);
					
					task.wait(2);
					print("Waiting...");
					
					sectionModel:Clone().Parent = savedSections;
					table.remove(sectionsToSave, table.find(sectionsToSave, sectionModel.Name));
					
					print("Successfully saved", sectionModel.Name);
				end;
			end;
		end;
		
		print("---------------------------------------------------------------------");
		print("All sections checked. Skip the tower if some of sections didn't save.");
	end;
end;

workspace.ChildAdded:Connect(function(child: Instance)
	if child:IsA("Model") and child.Name == "tower" then
		print("--------------------------- CYCLE STARTED ---------------------------");
		task.wait(1);
		teleportPlayer(child);
		task.wait(1);
		print("---------------------------- CYCLE ENDED ----------------------------");
	end;
end);
